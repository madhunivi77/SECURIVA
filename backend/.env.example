# ===== REQUIRED: API Keys =====
OPENAI_API_KEY="your_openai_api_key_here"
GROQ_API_KEY="your_groq_api_key_here"

# ===== REQUIRED: JWT Secret =====
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="your_jwt_secret_key_here"

# ===== Security Settings =====
ENVIRONMENT="development"  # Set to "production" when deploying
COOKIE_SECURE="False"  # Auto-set to True in production
COOKIE_SAMESITE="lax"  # "lax" works for same-site requests, "none" requires HTTPS

# ===== Logging Settings =====
ENABLE_TOOL_LOGGING="true"  # Set to "false" to disable tool call logging

# ===== Google OAuth Credentials =====
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# ===== Salesforce OAuth Credentials =====
# Get from: https://login.salesforce.com/ (Setup > App Manager > New Connected App)
SF_CLIENT_ID="your_salesforce_client_id_here"
SF_CLIENT_SECRET="your_salesforce_client_secret_here"

# ===== Telesign Credentials =====
# Get from: https://portal.telesign.com/
TELESIGN_CUSTOMER_ID="your_telesign_customer_id_here"
TELESIGN_API_KEY="your_telesign_api_key_here"
TELESIGN_USE_ENCRYPTED=true  # Set to true for production
TELESIGN_AUTO_REFRESH=true   # Enable credential auto-refresh
WHATSAPP_PREMIUM_ENABLED=false  # Set to true if using premium WhatsApp features
#SENDER_ID="your_phone_number_here"  # Phone number without + prefix

# ===== Voice AI (Deepgram) =====
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY="your_deepgram_api_key_here"

# ===== VAPI Configuration =====
# Set this to your public URL when deploying (e.g., using ngrok for local dev)
# Example: https://your-subdomain.ngrok-free.dev
VAPI_SERVER_URL="your_vapi_server_url_here"

# ============================================================================
# SERVER URLS (Optional - defaults provided)
# ============================================================================
BACKEND_URL="http://localhost:8000"
FRONTEND_URL="http://localhost:5173"
OAUTH_REDIRECT_URI="http://localhost:8000/callback"